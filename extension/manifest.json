{
  "manifest_version": 3,
  "name": "Timestamp Overlay",
  "version": "1.0",
  "description": "Injects a fixed UTC timestamp footer overlay on specific webpages for screenshot use.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Timestamp Overlay"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://virus-total-dan6.vercel.app/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}